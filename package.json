{
  "name": "vhdl-language-server",
  "version": "0.3.2",
  "description": "TypeScript-based VHDL Language Server (LSP) with optional GHDL integration",
  "main": "dist/server.js",
  "bin": {
    "vhdl-language-server": "dist/server.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -p tsconfig.json --watch",
    "test": "jest"
  },
  "keywords": [
    "vhdl",
    "language-server",
    "lsp",
    "ghdl"
  ],
  "license": "MIT",
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.test.json"
      }
    }
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
